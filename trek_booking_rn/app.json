{
  "expo": {
    "name": "Nepal Trek Explorer",
    "slug": "trek-booking-rn",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1E3A2C"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tu.trekbooking"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1E3A2C"
      },
      "package": "com.tu.trekbooking"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
